# ─────────────────────────────────────────────────────────────
# Contract Intake Navigator — 환경변수 설정 가이드
# ─────────────────────────────────────────────────────────────
# 로컬 개발: 이 파일을 .env.local 로 복사 후 값을 입력하세요.
# Vercel 배포: 대시보드 → Settings → Environment Variables 에 등록하세요.
# ⚠ .env.local 파일은 절대 git에 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────

# ── [서버 전용] Anthropic API 키 ──────────────────────────────
# VITE_ 접두사 없음 → 브라우저에 노출되지 않습니다.
# Vercel Serverless Function(api/analyze.js)에서만 사용됩니다.
# 설정 시 사용자가 브라우저에 API 키를 별도 입력하지 않아도 AI 분석 가능.
ANTHROPIC_API_KEY=your_api_key_here

# ── [클라이언트] Anthropic API 키 (선택) ──────────────────────
# 서버 키(ANTHROPIC_API_KEY)가 설정된 경우 이 값은 사용되지 않습니다.
# 서버 키 없이 개인 개발/테스트 시에만 사용하세요.
VITE_ANTHROPIC_API_KEY=your_api_key_here

# ── 표준계약서 파일 링크 베이스 URL ──────────────────────────
# 설정 시 Step4 각 계약서에 "파일 열기 →" 링크가 활성화됩니다.
# 각 계약서 URL = {VITE_TEMPLATE_BASE_URL}/{계약서 코드}
# 예: https://yourcompany.sharepoint.com/sites/legal/templates/NDA-BI
VITE_TEMPLATE_BASE_URL=

# ── NavDrawer 관련 링크 (미설정 시 링크 섹션 자동 숨김) ──────
VITE_LEGAL_PORTAL_URL=
VITE_TEMPLATE_LIBRARY_URL=
VITE_LEGAL_CONTACT_URL=

# ── CORS 허용 오리진 (서버사이드, 선택) ─────────────────────
# 보안 강화 시 실제 배포 도메인으로 설정하세요.
# 예: https://cin.vercel.app
ALLOWED_ORIGIN=
